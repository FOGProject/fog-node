<div class="login-box">
  <div class="login-logo">
    <a href="#"><b>FOG</b> Project</a>
  </div>
  <div class="card">
    <div class="card-body login-card-body">
      <p class="login-box-msg">Sign in to start your session</p>
      <% if (typeof req !== 'undefined' && req.query && req.query.failed) { %>
      <div class="alert alert-danger">Invalid username or password.</div>
      <% } %>
      <form action="/login" method="post">
        <div class="input-group mb-3">
          <input name="username" type="text" class="form-control" placeholder="Username">
          <div class="input-group-text"><span class="fa fa-user"></span></div>
        </div>
        <div class="input-group mb-3">
          <input name="password" type="password" class="form-control" placeholder="Password">
          <div class="input-group-text"><span class="fa fa-lock"></span></div>
        </div>
        <div class="row">
          <!-- RememberMe and Sign in Buttons -->
          <div class="col-8">
            <div class="form-check">
              <input type="checkbox" class="form-check-input" id="remember" name="remember-me">
              <label class="form-check-label" for="remember">Remember Me</label>
            </div>
          </div>
          <div class="col-4">
            <button type="submit" class="btn btn-primary btn-block w-100">Sign In</button>
          </div>
        </div>
      </form>
    </div>
  </div>
</div>
<%- /* Expose server-rendered data as window.SAILS_LOCALS :: */ exposeLocalsToBrowser() %>
