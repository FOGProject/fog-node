  "comments": {
    "overrides": "Force-patch vulnerable transitive deps pinned by the abandoned sails-hook-grunt/less/request build chain. These are build-time deps; npm audit fix can't reach them because their parents are unmaintained. babel-traverse, request, one hoek advisory, js-yaml and minimatch are intentionally not overridden (no in-range patch / cross-major bumps would break the grunt build)."
  },
  "overrides": {
    "async": "^3.2.6",
    "form-data": "^4.0.4",
    "getobject": "^1.0.0",
    "grunt": "$grunt",
    "hoek": "$hoek",
